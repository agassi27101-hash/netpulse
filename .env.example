# Copy this file to .env and adjust values before running NetPulse.

# Web server port
PORT=4000

# Where the SQLite database file is stored (created automatically)
DB_PATH=./data/netpulse.db

# How often (in seconds) every enabled device is checked.
# Can also be changed live from the Settings page without restarting.
POLL_INTERVAL_SECONDS=30

# How long to wait for a ping/SNMP reply before treating it as a failure
DEVICE_TIMEOUT_MS=3000

# Consecutive failed checks before a device is marked "down" (1 failure = "warning")
FAILS_BEFORE_DOWN=2

# --- Email alerts (optional) ---
# Leave SMTP_HOST blank to disable email notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=alerts@netpulse.local
ALERT_EMAIL_TO=

# --- Webhook alerts (optional) ---
# Any URL that accepts a JSON POST body (Slack incoming webhook, Discord, generic endpoint).
# Leave blank to disable.
ALERT_WEBHOOK_URL=
